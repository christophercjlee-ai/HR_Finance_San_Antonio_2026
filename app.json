{
  "expo": {
    "name": "Graham Conference",
    "slug": "graham-conference",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "graham-conference",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A6EB0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grahampackaging.conference",
      "infoPlist": {
        "NSCalendarsUsageDescription": "We need access to your calendar to add conference events.",
        "NSPhotoLibraryUsageDescription": "We need access to your photos to upload conference photos.",
        "NSCameraUsageDescription": "We need camera access to take conference photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A6EB0"
      },
      "package": "com.grahampackaging.conference",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_CALENDAR",
        "WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/pwa-icons/icon-96x96.png",
      "name": "Graham Conference",
      "shortName": "Graham Conf",
      "description": "Official app for the Graham Packaging HR & Finance Conference",
      "backgroundColor": "#0A6EB0",
      "themeColor": "#0A6EB0"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0A6EB0"
        }
      ],
      "expo-calendar",
      "expo-image-picker",
      "expo-document-picker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
